# Pulse backend — environment example
APP_NAME=Pulse
APP_SHORT=Pulse
COMPANY=SportConnect

# Server
PORT=4000

# Security
JWT_SECRET=change-me

# Database
DB_FILE=./data/pulse.db

# (Optional) CORS allowed origins — comma separated
